generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//enums
enum interviewOutcome{ 
  OFFER
  REJECTED  
  NO_RESPONSE  
  WITHDRAWN
  }

  enum SystemRole{
    ADMIN
    USER
  }

//model
model User{
  id Int @id @default(autoincrement())
  role SystemRole @default(USER)
  name String
  email String @unique
  password String
  age Int 
  yearsOfExperience Int 
  current_role String
  industry String
  tags Tag[]
  experience Experience[]
  comments Comment[]
  refresh_tokens RefreshTokens[]
}

model Experience{
  id Int @id @default(autoincrement())
  userId Int
  company String
  role String
  roundsCount Int
  difficulty Int
  outcome interviewOutcome
  content String
  interviewDate DateTime
  comments Comment[]
  tags Tag[]
  user User @relation(fields:[userId],references:[id],onDelete:Cascade)
}

model Comment{
  id Int @id @default(autoincrement())
  userId Int 
  experienceId Int
  comment String
  user User @relation(fields:[userId],references:[id],onDelete:Cascade)
  experience Experience @relation(fields:[experienceId],references:[id],onDelete:Cascade)
}

model Tag{
  id Int @id @default(autoincrement())
  tagName String @unique
  createdByUserid Int?
  addedOn DateTime @default(now())
  experience Experience[]
  user User @relation(fields:[createdByUserid],references:[id],onDelete:setNull)
}

model RefreshTokens{
  id Int @id @default(autoincrement())
  token String @unique
  userId Int 
  expiresAt DateTime 
  createdAt DateTime @default(now())
  user User @relation(fields:[userId],references:[id],onDelete:Cascade)
  @@map("refresh_tokens")
}

